# ─── Groq API Keys (get free keys at console.groq.com) ───────────────────────
# Key 1 is required. Keys 2-4 are optional — leave blank if you have fewer.
# The rotator automatically moves to the next key when one hits a rate limit.

GROQ_API_KEY_1=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_2=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_3=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_4=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Database (choose one) ────────────────────────────────────────────────────
# Neon (recommended free):  https://neon.tech  → New project → Connection string
# Supabase (free):          https://supabase.com → Project Settings → Database → URI
# Local Docker:             postgresql://postgres:postgres@localhost:5432/studyos

DATABASE_URL=postgresql://user:password@host:5432/studyos

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-32-char-string

# ─── Observability (optional — free at langfuse.com) ─────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Models (defaults are fine — change only if you want a different Groq model)
GROQ_MODEL=llama-3.1-8b-instant
GROQ_MODEL_LARGE=llama-3.3-70b-versatile
