# Force LF line endings in the repository for all text files
# This prevents the "LF will be replaced by CRLF" warning on Windows
* text=auto eol=lf

# Explicitly LF for Python, JS/JSX, config files
*.py    text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.env   text eol=lf
*.env.* text eol=lf
*.txt   text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf
*.ini   text eol=lf
*.sh    text eol=lf
*.css   text eol=lf
*.html  text eol=lf

# Binary files — no line ending conversion
*.pdf   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
